# ───────────────────────────────────────────────────────────
# CORE
# ───────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
API_GLOBAL_PREFIX=api
# Comma-separated whitelist of allowed frontend origins (CORS)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175

# ───────────────────────────────────────────────────────────
# DATABASE (PostgreSQL + PgBouncer)
# ───────────────────────────────────────────────────────────
POSTGRES_USER=rms
POSTGRES_PASSWORD=rms_password
POSTGRES_DB=rms
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# App connects through PgBouncer (port 6432). pgbouncer=true is required by Prisma.
DATABASE_URL=postgresql://rms:rms_password@pgbouncer:6432/rms?pgbouncer=true
# Direct connection (migrations / introspection must bypass the pooler)
DIRECT_URL=postgresql://rms:rms_password@postgres:5432/rms
# Read replica (analytics / reporting). Falls back to DATABASE_URL if unset.
DATABASE_REPLICA_URL=postgresql://rms:rms_password@pgbouncer:6432/rms?pgbouncer=true

# ───────────────────────────────────────────────────────────
# REDIS
# ───────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ───────────────────────────────────────────────────────────
# AUTH / JWT
# ───────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# 32-byte (64 hex chars) key for AES-256-GCM encryption of sensitive fields
AES_256_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
BCRYPT_SALT_ROUNDS=12
TOTP_ISSUER=RMS-Platform

# ───────────────────────────────────────────────────────────
# OAUTH2
# ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:4000/api/auth/facebook/callback

# ───────────────────────────────────────────────────────────
# TWILIO (OTP / SMS)
# ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=

# ───────────────────────────────────────────────────────────
# NOTIFICATIONS
# ───────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@rms.local
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# ───────────────────────────────────────────────────────────
# AWS S3
# ───────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=rms-uploads

# ───────────────────────────────────────────────────────────
# GOOGLE MAPS
# ───────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ───────────────────────────────────────────────────────────
# PAYMENTS
# ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=

# ───────────────────────────────────────────────────────────
# RATE LIMITING
# ───────────────────────────────────────────────────────────
RATE_LIMIT_PUBLIC_PER_MIN=100
RATE_LIMIT_AUTH_PER_MIN=500
